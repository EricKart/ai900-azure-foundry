# =============================================================================
# AI-900 Azure AI Foundry — Environment Variables
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env  (or the setup script does it)
#   2. Fill in each value from the Azure Portal (see docs/01_azure_portal_setup.md)
#   3. NEVER commit the .env file — it contains secrets!
# =============================================================================

# ---------------------------------------------------------------------------
# Azure AI Services (multi-service) — Used by: Vision, Language, Content Safety
# ---------------------------------------------------------------------------
# Find this in Azure Portal > Your AI Services resource > Keys and Endpoint
AZURE_AI_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
AZURE_AI_KEY=

# ---------------------------------------------------------------------------
# Azure OpenAI — Used by: Generative AI notebook
# ---------------------------------------------------------------------------
# Find this in Azure AI Foundry portal > Your Project > Deployments
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ---------------------------------------------------------------------------
# Azure AI Speech — Used by: Speech AI notebook
# ---------------------------------------------------------------------------
# Find this in Azure Portal > Your Speech resource > Keys and Endpoint
# Note: Speech requires a REGION (e.g., eastus) not just an endpoint URL
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ---------------------------------------------------------------------------
# Azure Document Intelligence — Used by: Document Intelligence notebook
# ---------------------------------------------------------------------------
# If you created a standalone Document Intelligence resource, fill these in.
# Otherwise, the multi-service endpoint and key above often work too.
AZURE_DOC_INTEL_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=
